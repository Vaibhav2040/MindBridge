    "longest_class = avg_words.idxmax()\n",
    "shortest_class = avg_words.idxmin()\n",
    "\n",
    "print(\n",
    "    f\"Key insight: {longest_class} posts are longest \"\n",
    "    f\"(~{avg_words.max():.0f} words), while {shortest_class} posts are shortest \"\n",
    "    f\"(~{avg_words.min():.0f} words).\"\n",
    ")"

    "    fontsize=12,\n",
    "    color=TEXT_MAIN,\n",
    "    fontweight='bold'\n",
    ")\n",
    "\n",
    "ax2.set_title(\n",
    "    'Class Proportion',\n",
    "    color=TEXT_MAIN,\n",

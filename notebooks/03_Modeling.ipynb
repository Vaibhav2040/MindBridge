    "\n",
    "label_encoder_path = os.path.join(MODEL_DIR, \"label_encoder.pkl\")\n",
    "vectorizer_path = os.path.join(MODEL_DIR, \"tfidf_vectorizer.pkl\")\n",
    "\n",
    "required_files = [\n",
    "    x_train_path, x_val_path, x_test_path,\n",
